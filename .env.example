# Supabase
# Create these from your Supabase project settings later.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Athena / OpenAI provider boundary
# Server-only. Never expose these as NEXT_PUBLIC_* values.
OPENAI_PROVIDER_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ATHENA_REQUEST_TOKEN_LIMIT=4000
ATHENA_DAILY_TOKEN_BUDGET=50000
ATHENA_MONTHLY_SPEND_LIMIT_USD=

# Phase 21H voice/current-info honest-disabled boundaries
ATHENA_VOICE_STT_PROVIDER=noop
ATHENA_VOICE_TTS_PROVIDER=noop
CURRENT_INFO_PROVIDER_ENABLED=false
CURRENT_INFO_PROVIDER_KIND=noop
