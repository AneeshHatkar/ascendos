{
  "phase": "18E",
  "title": "Self-Experiment Contracts + Validators",
  "lifecycle_stages": [
    "draft",
    "planned",
    "baseline",
    "active",
    "paused",
    "completed",
    "reviewed",
    "archived",
    "invalid"
  ],
  "evaluation_readiness_states": [
    "ready",
    "ready_with_warnings",
    "not_ready",
    "invalid"
  ],
  "lesson_statuses": [
    "not_started",
    "drafted",
    "reviewed",
    "approved_for_memory_candidate"
  ],
  "templates": [
    "sleep_reset_experiment",
    "career_sprint_experiment",
    "learning_consistency_experiment",
