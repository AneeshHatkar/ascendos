  "validator_rules": [
    "registered primary metric",
    "registered supporting metrics",
    "baseline required before evaluation",
    "active range required before evaluation",
    "minimum baseline days",
    "minimum active days",
    "minimum measurements",
    "confounder disclosure",
    "no confident causal claims",
    "unsynced local context disclosure",
    "cached experiment context disclosure",
